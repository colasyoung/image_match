# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# imgbb (server-side only)
IMGBB_API_KEY=
# 设为 1 时关闭上传前色情类自动粗检（仅建议在无 TensorFlow Node 的运行时或本地调试使用）
# DISABLE_NSFW_SCREENING=1
# 可选：imgbb 自动删除时间（秒），官方允许 60–15552000；默认 2592000 = 30 天
# IMGBB_EXPIRATION_SECONDS=2592000

# 可选：总站管理台 /admin?key=与此值一致时，列出所有比赛及各自管理链接（勿泄露）
MASTER_ADMIN_SECRET=

# ---------------------------------------------------------------------------
# 可选：管理员「免每场比赛 10 张图」上传（与 MASTER_ADMIN_SECRET、manage_token 均无关）
# ---------------------------------------------------------------------------
# 变量名：ADMIN_IMAGE_UPLOAD_BYPASS_SECRET（填一条足够长的随机串；勿提交到 Git）
#
# 【写在哪里才能无限制上传】——分「服务端」和「浏览器侧」两层：
#
# 1) 服务端（必须配置，否则永远不生效）
#    - 本地：写在 .env.local 里，例如 ADMIN_IMAGE_UPLOAD_BYPASS_SECRET=你的随机串
#    - 线上（如 Vercel）：Project → Settings → Environment Variables → 新增同名变量并保存，
#      然后重新部署一次，让运行中的 Node 进程读到该值。
#    未配置时：接口一律按「每场比赛最多 10 张」拒绝超额上传。
#
# 2) 浏览器侧（把「与上面环境变量完全相同」的字符串交给上传请求）
#    上传接口会读表单字段 adminUploadBypassToken；与 ADMIN_IMAGE_UPLOAD_BYPASS_SECRET
#    完全一致时，服务端才取消 10 张限制。产品页不展示该入口；仅建议用受控链接通过
#    URL 查询参数 uploadBypass=<同一串密钥>（代码常量名见 src/lib/admin-upload-bypass.ts），
#    打开一次后会写入本机 sessionStorage，同域后续上传会自动带上。例如：
#      .../manage/你的slug?token=管理token&uploadBypass=同一串密钥
#      .../create?uploadBypass=同一串密钥
#    勿把带 uploadBypass= 的完整链接发到公网或聊天记录（会泄露密钥，且会进浏览器历史/Referer）。
#
# ADMIN_IMAGE_UPLOAD_BYPASS_SECRET=
